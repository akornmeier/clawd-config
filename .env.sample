# =============================================================================
# Claude Code Environment Variables
# Copy this file to .env.local and fill in your values:
#   cp .env.sample .env.local
# =============================================================================

# --- Core ---
ANTHROPIC_API_KEY=
ENGINEER_NAME=

# --- AI Services (optional) ---
OPENAI_API_KEY=
ELEVENLABS_API_KEY=
FIRECRAWL_API_KEY=

# --- GitHub ---
GITHUB_PERSONAL_ACCESS_TOKEN=

# --- Twilio SMS Notifications (used by /build-and-ship) ---
# Required for SMS notifications when PRs are ready for review.
# If not configured, falls back to iMessage on macOS.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# --- Notification Recipient ---
# Phone number for build-and-ship SMS notifications (E.164 format, e.g., +15551234567)
NOTIFICATION_PHONE=
